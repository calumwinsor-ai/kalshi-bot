# Kalshi API Configuration
# ========================

# Backend Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# Kalshi Credentials (NEVER commit with real values!)
# These are read by the backend server only
KALSHI_EMAIL=your-email@example.com
KALSHI_PASSWORD=your-password-here

# Frontend Configuration
VITE_API_BASE=http://localhost:5000
