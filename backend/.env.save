# Kalshi Trading Bot Configuration
# ===================================

# Backend Server Port
PORT=5001

# Node Environment
NODE_ENV=development

# ⚠️ SECURITY NOTE: API Private Key Storage
#
# Simplified Login Flow:
# 1. You paste only your API Key ID in the bot login form
# 2. Your Private Key is stored securely here (never shown in UI)
# 3. Bot uses both for API calls to Kalshi
# 4. Your Kalshi password is NEVER involved or stored
#
# Get your credentials from Kalshi.com → Settings → API Keys

# REQUIRED: Kalshi API Private Key
# ⚠️ IMPORTANT: Keep this secret! Do not commit this to GitHub
#
# How to get your Private Key:
# 1. Go to Kalshi.com and log in
# 2. Navigate to Settings →-----BEGIN RSA PRIVATE KEY-----)
# 4. Paste it below (keep the quotes for multi-line formatting)
#
# PRODUCTION: Replace with your REAL Kalshi Private Key
KALSHI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
YOUR_PRIVATE_KEY_HERE
-----END RSA PRIVATE KEY-----"

# Frontend Configuration
VITE_API_BASE=http://localhost:5001

# Optional: OAuth Configuration (for advanced setup)
# KALSHI_CLIENT_ID=your-client-id
# KALSHI_CLIENT_SECRET=your-client-secret
# KALSHI_REDIRECT_URI=http://localhost:5000/api/auth/oauth-callback
