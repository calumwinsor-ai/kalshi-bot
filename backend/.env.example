# Backend Server Port
PORT=5001

# Node Environment
NODE_ENV=production

# Kalshi API Private Key (from Kalshi.com → Settings → API Keys)
# Paste your actual private key here (the multi-line RSA key)
KALSHI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
YOUR_ACTUAL_PRIVATE_KEY_HERE
-----END RSA PRIVATE KEY-----"

# Frontend Configuration
VITE_API_BASE=http://localhost:5001
